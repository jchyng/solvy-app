# ─── Frontend (VITE_ prefix = exposed to browser) ──────────────
VITE_API_URL=/api/v1
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_SENTRY_DSN=

# ─── Backend (Cloudflare Workers secrets / wrangler.toml vars) ──
# Set via: wrangler secret put <KEY>
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
JWT_SECRET=
SENTRY_DSN=

# ─── Storage ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=solvy-uploads

# ─── AI Providers ────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=
OPENROUTER_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# ─── Observability ───────────────────────────────────────────────
POSTHOG_KEY=
POSTHOG_HOST=https://app.posthog.com

# ─── Email ───────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Payments (Week 6+) ──────────────────────────────────────────
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# ─── Core ────────────────────────────────────────────────────────
NODE_ENV=development
DATABASE_URL=
CORS_ORIGINS=http://localhost:5173
